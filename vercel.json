{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/compta_app.html", "destination": "/app", "permanent": true },
    { "source": "/compta_app",      "destination": "/app", "permanent": true },
    { "source": "/compta-app",      "destination": "/app", "permanent": true },
    { "source": "/pricing",         "destination": "/#tarifs", "permanent": true },
    { "source": "/pricing.html",    "destination": "/#tarifs", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
