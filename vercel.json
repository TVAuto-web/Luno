{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/compta_app.html", "destination": "/app", "permanent": true },
    { "source": "/compta_app",      "destination": "/app", "permanent": true },
    { "source": "/compta-app",      "destination": "/app", "permanent": true },
    { "source": "/pricing",         "destination": "/#tarifs", "permanent": true },
    { "source": "/pricing.html",    "destination": "/#tarifs", "permanent": true },
    { "source": "/auto-entrepreneur", "destination": "/#auto-entrepreneur", "permanent": true },
    { "source": "/sasu-sas",        "destination": "/#sasu-sas", "permanent": true },
    { "source": "/sarl-eurl",       "destination": "/#sasu-sas", "permanent": true },
    { "source": "/sci-lmnp",        "destination": "/#sci-lmnp", "permanent": true },
    { "source": "/cabinet-comptable", "destination": "/#cabinet-comptable", "permanent": true },
    { "source": "/aide",            "destination": "/#aide", "permanent": true },
    { "source": "/documentation",   "destination": "/#aide", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
